# Copy this file to .env and fill in real values

# Core selection
LLM_PROVIDER=anthropic
LLM_MODEL=claude-3-5-sonnet-latest

# Anthropic
ANTHROPIC_API_KEY=

# OpenAI
OPENAI_API_KEY=

# Google Gemini
GOOGLE_API_KEY=

# Ollama (local)
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Future enrichment toggle
ENABLE_ENRICHMENT=true

# Optional: override server port (defaults to 5000)
PORT=5000
